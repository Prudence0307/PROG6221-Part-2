<Window x:Class="CyberSecChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSec Awareness Bot"
        Height="700"
        Width="900"
        Background="#1B1F2A">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Header -->

        <Border Grid.Row="0"
                CornerRadius="10"
                Background="#263238"
                Padding="15"
                Margin="0 0 0 10">

            <StackPanel>

                <TextBlock
                    Foreground="Lime"
                    FontFamily="Consolas"
                    FontSize="14"
                    Text="
  _____       _
 / ____|     | |
| |      _ _ | |__
| |     | | || '_ \
| |____ | |_| | |_) |
 \_____|\__,_|_.__/

CYBERSECURITY BOT"/>

                <TextBlock
                    Text="🛡 Cyber Security Awareness Assistant"
                    Foreground="White"
                    FontSize="22"
                    FontWeight="Bold"/>
            </StackPanel>

        </Border>

        <!-- Chat Area -->

        <ScrollViewer Grid.Row="1">

            <ListBox Name="ChatList"
                     Background="#212121"
                     Foreground="White"/>

        </ScrollViewer>

        <!-- Input Area -->

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBox Name="txtInput"
                     FontSize="16"
                     Margin="0 0 10 0"/>

            <Button Grid.Column="1"
                    Name="btnSend"
                    Content="Send"
                    Background="#00C853"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="btnSend_Click"/>

        </Grid>

    </Grid>
</Window>
